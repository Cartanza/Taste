<!DOCTYPE html>
<html lang="{{@root.site.locale}}">

<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{meta_title}}</title>
    <link rel="stylesheet" href="{{asset "built/screen.css"}}">
    <link rel="stylesheet" href="{{asset "css/font-awesome.min.css"}}">
    
    {{#is "home"}}
        {{#if @root.site.cover_image}}
            <link rel="preload" as="image" href="{{@root.site.cover_image}}">
        {{/if}}
    {{/is}}

    <style>
        :root {
            --background-color: {{@root.custom.background_color}}
        }
    </style>

    <script>
        /* The script for calculating the color contrast was taken from
        https://gomakethings.com/dynamically-changing-the-text-color-based-on-background-color-contrast-with-vanilla-js/ */
        var accentColor = getComputedStyle(document.documentElement).getPropertyValue('--background-color');
        accentColor = accentColor.trim().slice(1);
        var r = parseInt(accentColor.substr(0, 2), 16);
        var g = parseInt(accentColor.substr(2, 2), 16);
        var b = parseInt(accentColor.substr(4, 2), 16);
        var yiq = ((r * 299) + (g * 587) + (b * 114)) / 1000;
        var textColor = (yiq >= 128) ? 'dark' : 'light';

        document.documentElement.className = `has-${textColor}-text`;
    </script>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    {{#match @root.custom.style "Elegant"}}
        <link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;1,400;1,600&display=swap" rel="stylesheet">
    {{else}}
        <link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,400;0,600;0,700;1,400;1,700&display=swap" rel="stylesheet">
    {{/match}}

    {{ghost_head}}
</head>

<body class="{{body_class}}{{{block "body_class"}}} is-font-{{#match @root.custom.style "Elegant"}}serif{{else}}sans{{/match}}">
<div class="gh-site">

    {{#is "home"}}
        {{#match @root.custom.header_action "Subscribe"}}
            {{> partials/components/navbar navigationLayout=@root.custom.navigation_layout hideSubscribeButton=true}}
        {{else}}
            {{> partials/components/navbar navigationLayout=@root.custom.navigation_layout}}
        {{/match}}
    {{else}}
        {{> partials/components/navbar navigationLayout=@root.custom.navigation_layout}}
    {{/is}}

    {{~> body}}

    {{> partials/components/footer footerText=@root.custom.footer_text}}

</div>

{{#is "post, page"}}
    {{> partials/pswp}}
{{/is}}

<script>
    // Select the cart icon and header cart elements
    const cartIcon = document.querySelector('i.fs-12.fa.fa-shopping-bag');
    if(cartIcon) {
        const headerCart = document.querySelector('div.cartanza-header-cart');

        document.addEventListener('click', (event) => {
            if (cartIcon.contains(event.target)) {
                headerCart.classList.toggle('show-header-dropdown');
            } else if (!headerCart.contains(event.target)) {
                headerCart.classList.remove('show-header-dropdown');
            }
        });
        window.onload = function() {
            getCart();
        }
    }
</script>
<script>
    let wasInPortal = window.location.hash.includes('/portal/');

    function checkPortal() {
        const isInPortal = window.location.hash.includes('/portal/');
        if (isInPortal) {
            wasInPortal = true;
        } else if (wasInPortal) {
            wasInPortal = false;
            window.location.reload();
        }
    }

    window.addEventListener('hashchange', () => {
        checkPortal();
    });
    
    // Ghost Portal often uses history.replaceState to close, which doesn't trigger hashchange.
    // We check the hash every 500ms while we believe the portal is open.
    setInterval(checkPortal, 500);

    async function logout(event) {
        event.preventDefault();
        try {
            const response = await fetch('/members/api/session/', {
                method: 'DELETE', // HTTP method
                headers: {
                    'Content-Type': 'application/json' // Specify JSON payload
                },
                body: JSON.stringify({ all: false }) // Convert the data to JSON string
            });

            if (response.ok) {
                console.log('Session logged out successfully');
                window.location.href = '/';
            } else {
                console.error('Failed to logout of session:', response.status, response.statusText);
            }
        } catch (error) {
            console.error('Error:', error);
        }
    }
</script>
{{ghost_foot}}
<script src="{{asset "built/main.min.js"}}"></script>
</body>

</html>
